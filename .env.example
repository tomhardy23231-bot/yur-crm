# Supabase — заполняется значениями из вывода `npx supabase start`
# Локально эти ключи безопасны (только для dev), на проде — секреты в Vercel/host env.

# Публичный URL Supabase (виден клиенту)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Публичный анонимный ключ (виден клиенту). Используется браузерным клиентом
# supabase-js, RLS работает поверх него на стороне БД.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role (полный обход RLS). НИКОГДА не отдавать клиенту.
# Используется ТОЛЬКО:
#   - в скриптах сидинга (`npm run db:seed`)
#   - в системных серверных задачах, явно требующих обхода RLS
# Никогда — для обычных пользовательских запросов из роутов/Server Actions.
SUPABASE_SERVICE_ROLE_KEY=

# ── OnlyOffice Document Server (просмотр/правка Word/Excel прямо в системе) ──
# Запуск локально (Docker), один раз:
#   docker run -d --name onlyoffice -p 8080:80 \
#     -e JWT_ENABLED=true -e JWT_SECRET=<тот же секрет, что ниже> \
#     onlyoffice/documentserver
#
# URL Document Server, который грузит БРАУЗЕР (api.js редактора).
NEXT_PUBLIC_ONLYOFFICE_URL=http://localhost:8080
# URL DS, по которому НАШ сервер скачивает сохранённый файл (обычно тот же).
ONLYOFFICE_INTERNAL_URL=http://localhost:8080
# Как наш app достижим ИЗ контейнера DS (document.url + callbackUrl).
# Локально в Docker Desktop — host.docker.internal; на проде — публичный URL app.
APP_URL_FOR_ONLYOFFICE=http://host.docker.internal:3000
# Общий JWT-секрет: должен совпадать с JWT_SECRET контейнера DS. Сгенерировать:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ONLYOFFICE_JWT_SECRET=

# ── Telegram-напоминания и ICS-календарь (v3 Сессия 8) ──
# Токен бота от @BotFather. Без него рассылка работает в dry-run (ничего не шлёт).
TELEGRAM_BOT_TOKEN=
# Секрет вебхука: задаётся при setWebhook (?secret_token=...), Telegram шлёт его в
# заголовке x-telegram-bot-api-secret-token. Любая строка; сгенерировать как выше.
TELEGRAM_WEBHOOK_SECRET=
# Имя бота без @ (для инструкции привязки в профиле; виден клиенту).
NEXT_PUBLIC_TELEGRAM_BOT_NAME=
# Секрет cron-рассылки: Vercel Cron шлёт его как Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
