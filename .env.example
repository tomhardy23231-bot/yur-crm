# Supabase — заполняется значениями из вывода `npx supabase start`
# Локально эти ключи безопасны (только для dev), на проде — секреты в Vercel/host env.

# Публичный URL Supabase (виден клиенту)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Публичный анонимный ключ (виден клиенту). Используется браузерным клиентом
# supabase-js, RLS работает поверх него на стороне БД.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role (полный обход RLS). НИКОГДА не отдавать клиенту.
# Используется ТОЛЬКО:
#   - в скриптах сидинга (`npm run db:seed`)
#   - в системных серверных задачах, явно требующих обхода RLS
# Никогда — для обычных пользовательских запросов из роутов/Server Actions.
SUPABASE_SERVICE_ROLE_KEY=
