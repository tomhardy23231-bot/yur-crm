# ── Postgres / Neon (цикл v4 — целевой стек) ─────────────────────────────────
# Три строки подключения (Neon Console → Connect; регион Frankfurt):
#
# Пользовательский пул (роль app_user, POOLED «-pooler» хост). Все
# пользовательские запросы; RLS применяется, обход невозможен (NOBYPASSRLS).
DATABASE_URL_APP=
# Админский пул (owner-роль БД, POOLED). Обходит RLS — только machine-роуты,
# owner-экшены учёток, seed (ESLint-гард: импорт @/lib/db/admin вне allowlist
# валит линт). Аналог прежнего service_role.
DATABASE_URL_ADMIN=
# Owner-роль, DIRECT хост (без «-pooler») — миграции (npm run db:migrate),
# ACL-аудит, prisma db pull. НЕ для приложения.
DATABASE_URL_ADMIN_DIRECT=
# Маркер окружения БД: dev | prod. При prod сид отказывается работать
# (ALLOW_NONLOCAL_SEED=1 — осознанный override).
YUR_DB_ENV=dev

# Секрет подписи JWT-сессий (свой auth, цикл v4 с2): >= 32 символов, случайный.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Смена секрета мгновенно разлогинивает ВСЕХ (все подписи становятся чужими).
AUTH_SECRET=

# ── Файлохранилище (цикл v4 с5): сканы/акты по делам ─────────────────────────
# Провайдер: local (по умолчанию — файлы на диске, для dev/тестов) | s3 (R2/MinIO).
# На проде — s3 (Cloudflare R2). local НЕ требует облака и работает сразу.
STORAGE_PROVIDER=local
# Локальный провайдер: папка для файлов (по умолчанию .storage/ в корне, в .gitignore).
# STORAGE_LOCAL_DIR=.storage
#
# S3-совместимый провайдер (STORAGE_PROVIDER=s3) — Cloudflare R2 сейчас,
# MinIO/диск на корп-сервере потом (тот же протокол S3, меняется только env):
#   R2: S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com, S3_REGION=auto
#   MinIO: свой S3_ENDPOINT + S3_REGION + S3_FORCE_PATH_STYLE=true
# Аккаунт R2 заводится НА ВЛАДЕЛЬЦА (bus factor, нужна карта даже на free-tier).
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=case-documents
# S3_FORCE_PATH_STYLE=true   # только для MinIO; R2 — не задавать

# ── Supabase — ТОЛЬКО как ИСТОЧНИК переноса файлов (цикл v4) ──────────────────
# Приложение на Supabase больше НЕ ходит (auth/данные/файлы — свои, сессии 2–5).
# Эти две строки читает единственный скрипт `npm run migrate:files`
# (scripts/migrate-files.ts) — качает сканы/акты из старого Storage прода в R2.
# Значения — из прод-проекта Supabase (Settings → API). УДАЛИТЬ после переноса
# файлов и переезда прода (сессия 7).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── OnlyOffice Document Server (просмотр/правка Word/Excel прямо в системе) ──
# Запуск локально (Docker), один раз:
#   docker run -d --name onlyoffice -p 8080:80 \
#     -e JWT_ENABLED=true -e JWT_SECRET=<тот же секрет, что ниже> \
#     onlyoffice/documentserver
#
# URL Document Server, который грузит БРАУЗЕР (api.js редактора).
NEXT_PUBLIC_ONLYOFFICE_URL=http://localhost:8080
# URL DS, по которому НАШ сервер скачивает сохранённый файл (обычно тот же).
ONLYOFFICE_INTERNAL_URL=http://localhost:8080
# Как наш app достижим ИЗ контейнера DS (document.url + callbackUrl).
# Локально в Docker Desktop — host.docker.internal; на проде — публичный URL app.
APP_URL_FOR_ONLYOFFICE=http://host.docker.internal:3000
# Общий JWT-секрет: должен совпадать с JWT_SECRET контейнера DS. Сгенерировать:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ONLYOFFICE_JWT_SECRET=

# ── Telegram-напоминания и ICS-календарь (v3 Сессия 8) ──
# Токен бота от @BotFather. Без него рассылка работает в dry-run (ничего не шлёт).
TELEGRAM_BOT_TOKEN=
# Секрет вебхука: задаётся при setWebhook (?secret_token=...), Telegram шлёт его в
# заголовке x-telegram-bot-api-secret-token. Любая строка; сгенерировать как выше.
TELEGRAM_WEBHOOK_SECRET=
# Имя бота без @ (для инструкции привязки в профиле; виден клиенту).
NEXT_PUBLIC_TELEGRAM_BOT_NAME=
# Секрет cron-рассылки: Vercel Cron шлёт его как Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
