{
  "name": "yur-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "node --env-file=.env.local --import tsx scripts/db-migrate.ts",
    "db:acl-audit": "node --env-file=.env.local --import tsx scripts/acl-audit.ts",
    "db:seed": "node --env-file=.env.local --import tsx scripts/seed.ts",
    "db:seed:demo": "node --env-file=.env.local --import tsx scripts/seed-demo.ts",
    "smoke:rls": "node --env-file=.env.local --import tsx scripts/smoke-rls.ts",
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/s3-request-presigner": "^3.1087.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "driver.js": "^1.4.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.42.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
