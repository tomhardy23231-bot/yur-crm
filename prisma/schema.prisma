  @@index([closed_at(sort: Desc)], map: "cases_archive_closed_at_idx", where: raw("(archived_at IS NOT NULL)"))
  @@index([archived_at(sort: Desc)], where: raw("(archived_at IS NOT NULL)"))
  @@index([archived_by])
  @@index([case_type])
  @@index([category])
  @@index([client_id], map: "cases_client_idx")
  @@index([lawyer_id], map: "cases_lawyer_idx")
  @@index([opened_at(sort: Desc)])
  @@index([responsible_id], map: "cases_responsible_idx")
