  clients                           clients              @relation(fields: [client_id], references: [id], onUpdate: NoAction)
  users_cases_lawyer_idTousers      public_users         @relation("cases_lawyer_idTousers", fields: [lawyer_id], references: [id], onUpdate: NoAction)
  users_cases_responsible_idTousers public_users         @relation("cases_responsible_idTousers", fields: [responsible_id], references: [id], onUpdate: NoAction)
  cash_entries                      cash_entries[]
  documents                         documents[]
  payment_plan_items                payment_plan_items[]
  payments                          payments[]
  payout_allocations                payout_allocations[]
  payroll_ledger                    payroll_ledger[]
