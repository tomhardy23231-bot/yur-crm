  expert_rate_override              Decimal?             @db.Decimal(5, 2)
  dual_rate_override                Decimal?             @db.Decimal(5, 2)
  accrual_mode                      accrual_mode         @default(on_completion)
  overpaid                          Decimal              @default(0) @db.Decimal(14, 2)
  closed_without_act                Boolean              @default(false)
  stage_changed_at                  DateTime             @default(now()) @db.Timestamptz(6)
  archived_at                       DateTime?            @db.Timestamptz(6)
