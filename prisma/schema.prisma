model absences {
  id                               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                          String       @db.Uuid
  kind                             String       @default("vacation")
  starts_on                        DateTime     @db.Date
  ends_on                          DateTime     @db.Date
  note                             String?
  created_by                       String       @db.Uuid
  created_at                       DateTime     @default(now()) @db.Timestamptz(6)
  users_absences_created_byTousers public_users @relation("absences_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  users_absences_user_idTousers    public_users @relation("absences_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_by])
  @@index([starts_on, ends_on], map: "absences_range_idx")
  @@index([user_id], map: "absences_user_idx")
  @@schema("public")
}

