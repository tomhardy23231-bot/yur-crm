model case_acts {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id          String       @db.Uuid
  number           Int          @unique @default(autoincrement())
  service_name     String       @default("Юридичні послуги")
  service_period   String?
  amount           Decimal      @db.Decimal(14, 2)
  confirmed_amount Decimal?     @db.Decimal(14, 2)
  completion       String?
  status           String       @default("issued")
  issued_at        DateTime     @default(dbgenerated("CURRENT_DATE")) @db.Date
  paid_at          DateTime?    @db.Date
  scan_document_id String?      @db.Uuid
  note             String?
  created_by       String       @db.Uuid
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  cases            cases        @relation(fields: [case_id], references: [id], onUpdate: NoAction)
  users            public_users @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  documents        documents?   @relation(fields: [scan_document_id], references: [id], onUpdate: NoAction)
  payments         payments?

  @@index([case_id, created_at(sort: Desc)], map: "case_acts_case_idx")
  @@index([created_by])
  @@index([scan_document_id])
  @@index([status])
  @@schema("public")
}

